# ──────────────────────────────────────────────────────────────
# Veer Aluminium & Fabrication — Environment Variables
# Copy this file to `.env` and fill in real values.
# ──────────────────────────────────────────────────────────────

# PostgreSQL connection string (Neon, Supabase, Railway, or local)
DATABASE_URL="postgresql://user:password@localhost:5432/veer_aluminium?schema=public"

# Public site URL (used for SEO canonical, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL="https://veeraluminium.com"

# Admin CMS credentials (a bootstrap admin is created from these on seed)
ADMIN_EMAIL="admin@veeraluminium.com"
ADMIN_PASSWORD="ChangeThisStrongPassword#2026"

# JWT secret for admin session cookies (use a long random string)
AUTH_SECRET="replace-with-a-64-char-random-secret-string-generated-securely"

# Business contact details (surfaced in UI + schema)
NEXT_PUBLIC_BUSINESS_PHONE="+919999999999"
NEXT_PUBLIC_WHATSAPP_NUMBER="919999999999"
NEXT_PUBLIC_BUSINESS_EMAIL="info@veeraluminium.com"

# Google Maps embed (optional — falls back to a generic embed if empty)
NEXT_PUBLIC_GOOGLE_MAPS_EMBED=""

# Optional: SMTP for sending quote emails (leave blank to disable)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Veer Aluminium <no-reply@veeraluminium.com>"
